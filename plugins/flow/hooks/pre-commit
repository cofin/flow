#!/usr/bin/env python3
import os
import sys
import json
import re
import subprocess
import shutil
from datetime import datetime

def run_cmd(cmd: list[str]) -> str | None:
    try:
        result = subprocess.run(
            cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True, check=True
        )
        return result.stdout
    except subprocess.CalledProcessError as e:
        print(f"Error running {' '.join(cmd)}: {e.stderr}", file=sys.stderr)
        return None

def detect_backend() -> str:
    if shutil.which("bd") is not None:
        return "bd"
    if shutil.which("br") is not None:
        return "br"
    return "none"

def _fetch_children_bd(epic_id: str) -> list[dict] | None:
    # bd show <id> --json returns a list containing one dict; children live in `dependencies`
    out = run_cmd(["bd", "show", epic_id, "--json"])
    if not out:
        return None
    try:
        data = json.loads(out)
    except json.JSONDecodeError:
        return None
    if isinstance(data, list) and data:
        data = data[0]
    if not isinstance(data, dict):
        return None
    deps = data.get("dependencies", []) or []
    return [d for d in deps if isinstance(d, dict)]

def _fetch_children_br(epic_id: str) -> list[dict] | None:
    # br show <id> --format json returns dict(s) with `dependents` filtered to parent-child
    out = run_cmd(["br", "show", epic_id, "--format", "json"])
    if not out:
        return None
    try:
        data = json.loads(out)
    except json.JSONDecodeError:
        return None
    if isinstance(data, list) and data:
        data = data[0]
    if not isinstance(data, dict):
        return None
    raw = data.get("dependents", []) or []
    return [d for d in raw if isinstance(d, dict) and d.get("dependency_type") == "parent-child"]

def get_active_flows() -> list[str]:
    flows_md = ".agents/flows.md"
    if not os.path.exists(flows_md):
        return []

    with open(flows_md, 'r') as f:
        content = f.read()

    # Extract flow ids from the active flows section.
    # Matches: *Link: [./specs/<flow_id>/](./specs/<flow_id>/)*
    active_section_match = re.search(r'## Active Flows(.*?)## Archived', content, re.DOTALL | re.IGNORECASE)
    if not active_section_match:
        active_section_match = re.search(r'## Active Flows(.*)', content, re.DOTALL | re.IGNORECASE)
        if not active_section_match:
            return []

    active_section = active_section_match.group(1)
    flow_ids = re.findall(r'\.\/specs\/([^/]+)\/', active_section)
    return list(set(flow_ids))

def sync_flow(backend: str, flow_id: str) -> bool:
    spec_path = f".agents/specs/{flow_id}/spec.md"
    meta_path = f".agents/specs/{flow_id}/metadata.json"

    if not os.path.exists(spec_path) or not os.path.exists(meta_path):
        return False

    try:
        with open(meta_path, 'r') as f:
            meta = json.load(f)
    except json.JSONDecodeError:
        return False

    beads_epic_id = meta.get("beads_epic_id")
    if not beads_epic_id:
        return False

    tasks = _fetch_children_bd(beads_epic_id) if backend == "bd" else _fetch_children_br(beads_epic_id)
    if tasks is None:
        return False

    status_map = {
        "pending": "[ ]",
        "open": "[ ]",
        "in_progress": "[~]",
        "completed": "[x]",
        "closed": "[x]",
        "blocked": "[!]",
        "skipped": "[-]"
    }

    task_info = []
    for t in tasks:
        title = t.get("description", t.get("title", ""))
        status = str(t.get("status", "open")).lower()
        marker = status_map.get(status, "[ ]")
        task_info.append({"title": title, "marker": marker})

    with open(spec_path, 'r') as f:
        spec_content = f.readlines()

    updated_lines = []
    changes_made = False
    task_regex = re.compile(r'^(\s*-\s*)\[( |x|~|!|-)\](.*)', re.IGNORECASE)

    for line in spec_content:
        match = task_regex.match(line)
        if match:
            prefix = match.group(1)
            content = match.group(3)
            matched_marker = None
            for t in task_info:
                if t["title"] and (t["title"].lower() in content.lower() or content.lower().strip() in t["title"].lower()):
                    matched_marker = t["marker"]
                    break

            if matched_marker and match.group(2) != matched_marker[1]:
                updated_lines.append(f"{prefix}{matched_marker}{content}\n")
                changes_made = True
            else:
                updated_lines.append(line)
        else:
            updated_lines.append(line)

    if changes_made:
        with open(spec_path, 'w') as f:
            f.writelines(updated_lines)

        meta["synced_at"] = datetime.utcnow().strftime("%Y-%m-%dT%H:%M:%SZ")
        meta["updated_at"] = meta["synced_at"]
        with open(meta_path, 'w') as f:
            json.dump(meta, f, indent=2)
            f.write("\n")

        run_cmd(["git", "add", spec_path, meta_path])
        return True

    return False

def main() -> None:
    if os.environ.get("SKIP_FLOW_SYNC") == "1":
        sys.exit(0)

    if not os.path.exists(".agents") or not os.path.exists(".beads"):
        sys.exit(0)

    backend = detect_backend()
    if backend == "none":
        # No Beads CLI on PATH — degrade silently so commits are not blocked.
        sys.exit(0)

    try:
        subprocess.run([backend, "--version"], stdout=subprocess.PIPE, stderr=subprocess.PIPE, check=True)
    except (FileNotFoundError, subprocess.CalledProcessError):
        sys.exit(0)

    # br buffers writes and needs an explicit flush; bd writes to SQLite directly.
    if backend == "br":
        run_cmd(["br", "sync", "--flush-only"])

    flows = get_active_flows()
    synced_any = False
    for f in flows:
        if sync_flow(backend, f):
            synced_any = True

    if synced_any:
        print("[Flow] Auto-synced Beads state to spec.md")

if __name__ == "__main__":
    main()
