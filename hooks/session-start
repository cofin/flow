#!/usr/bin/env bash
# Consolidated SessionStart hook for Flow framework
# Supports: Gemini CLI, Claude Code, OpenCode, Codex CLI, Cursor IDE
#
# Detects host-specific environment variables to return the correct JSON schema.

set -euo pipefail

# Determine script and plugin root directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# 1. Gather Context via detect-env.sh (Cross-platform logic)
CONTEXT=$("${SCRIPT_DIR}/detect-env.sh")

# 2. Add Host-Specific Logic (Optional additions to context)
# For now, we use the output of detect-env.sh as the primary context.

# 3. Escape for JSON
# Python is most reliable for cross-platform multi-line escaping
ESCAPED_CONTEXT=$(echo "$CONTEXT" | python3 -c 'import json, sys; print(json.dumps(sys.stdin.read()))')

# 4. Output based on detected host
if [[ -n "${CLAUDE_PLUGIN_ROOT:-}" ]] || [[ -n "${OPENCODE_PLUGIN_ROOT:-}" ]]; then
    # Claude Code / OpenCode
    printf '{
  "hookSpecificOutput": {
    "hookEventName": "SessionStart",
    "additionalContext": %s
  }
}
' "$ESCAPED_CONTEXT"
elif [[ -n "${CODEX_PLUGIN_ROOT:-}" ]]; then
    # Codex CLI
    printf '{
  "additional_context": %s
}
' "$ESCAPED_CONTEXT"
elif [[ -n "${CURSOR_PLUGIN_ROOT:-}" ]]; then
    # Cursor IDE
    printf '{
  "additional_context": %s
}
' "$ESCAPED_CONTEXT"
else
    # Default to Gemini CLI systemMessage schema
    printf '{"systemMessage": %s}\n' "$ESCAPED_CONTEXT"
fi
